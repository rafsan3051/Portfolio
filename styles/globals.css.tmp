:root {
  --background: 240 10% 4%;
  --foreground: 180 100% 95%;
  /* Slightly cyan tinted white */
  --card: 240 10% 6%;
  --card-foreground: 0 0% 98%;
  --popover: 240 10% 6%;
  --popover-foreground: 0 0% 98%;
  --primary: 180 100% 50%;
  /* Neon Cyan */
  --primary-foreground: 240 10% 4%;
  --secondary: 270 100% 60%;
  /* Electric Purple */
  --secondary-foreground: 0 0% 98%;
  --muted: 240 10% 12%;
  --muted-foreground: 240 5% 64.9%;
  --accent: 330 100% 50%;
  /* Neon Pink */
  --accent-foreground: 0 0% 98%;
  --destructive: 0 84.2% 60.2%;
  --destructive-foreground: 0 0% 98%;
  --border: 180 100% 50%;
  /* Default border glow */
  --input: 240 10% 12%;
  --ring: 180 100% 50%;
  --radius: 0.5rem;
  /* sharper corners for futuristic feel */
}

/* Force dark mode */

.light {
  --background: 240 10% 4%;
  --foreground: 180 100% 95%;
  --card: 240 10% 6%;
  --card-foreground: 0 0% 98%;
  --popover: 240 10% 6%;
  --popover-foreground: 0 0% 98%;
  --primary: 180 100% 50%;
  --primary-foreground: 240 10% 4%;
  --secondary: 270 100% 60%;
  --secondary-foreground: 0 0% 98%;
  --muted: 240 10% 12%;
  --muted-foreground: 240 5% 64.9%;
  --accent: 330 100% 50%;
  --accent-foreground: 0 0% 98%;
  --border: 180 100% 50%;
  --input: 240 10% 12%;
  --ring: 180 100% 50%;
}

* {
  border-color: hsl(var(--border) / 0.2);
  /* subtle borders by default */
}

html {
  scroll-behavior: smooth;
}

body {
  background-color: hsl(var(--background));
  color: hsl(var(--foreground));
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body *::-moz-selection {
  --tw-bg-opacity: 1;
  background-color: rgb(0 243 255 / var(--tw-bg-opacity, 1));
  --tw-text-opacity: 1;
  color: rgb(0 0 0 / var(--tw-text-opacity, 1));
}

body *::selection {
  --tw-bg-opacity: 1;
  background-color: rgb(0 243 255 / var(--tw-bg-opacity, 1));
  --tw-text-opacity: 1;
  color: rgb(0 0 0 / var(--tw-text-opacity, 1));
}

body::-moz-selection {
  --tw-bg-opacity: 1;
  background-color: rgb(0 243 255 / var(--tw-bg-opacity, 1));
  --tw-text-opacity: 1;
  color: rgb(0 0 0 / var(--tw-text-opacity, 1));
}

body::selection {
  --tw-bg-opacity: 1;
  background-color: rgb(0 243 255 / var(--tw-bg-opacity, 1));
  --tw-text-opacity: 1;
  color: rgb(0 0 0 / var(--tw-text-opacity, 1));
}

body {
  background-image: 
      radial-gradient(circle at 15% 50%, rgba(176, 38, 255, 0.08), transparent 25%),
      radial-gradient(circle at 85% 30%, rgba(0, 243, 255, 0.08), transparent 25%);
  background-attachment: fixed;
}

/* Grid overlay for terminal vibe */

.bg-grid {
  background-size: 40px 40px;
  background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
  -webkit-mask-image: linear-gradient(to bottom, transparent, black, transparent);
          mask-image: linear-gradient(to bottom, transparent, black, transparent);
}

/* Noise overlay */

.bg-noise {
  position: relative;
}

.bg-noise::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 50;
}

.glass {
  backdrop-filter: blur(16px) saturate(180%);
  background: rgba(10, 10, 10, 0.65);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
}

.glass-panel {
  backdrop-filter: blur(16px) saturate(180%);
  background: rgba(10, 10, 10, 0.65);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  position: relative;
  overflow: hidden;
  border-radius: 0.75rem;
}

.glass-panel::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(to bottom right, rgba(0, 243, 255, 0.3), rgba(176, 38, 255, 0.1));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* Scanline effect */

.scanline {
  width: 100%;
  height: 100px;
  z-index: 10;
  position: absolute;
  pointer-events: none;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(0, 243, 255, 0.1) 50%, rgba(0, 0, 0, 0) 100%);
  opacity: 0.1;
  animation: scanline 8s linear infinite;
}

@keyframes scanline {
  0% {
    transform: translateY(-100%);
  }

  100% {
    transform: translateY(100vh);
  }
}

