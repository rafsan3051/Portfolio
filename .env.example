# Environment Variables for Portfolio Dashboard

# GitHub Configuration
# Optional: Increase rate limits for GitHub API (create at https://github.com/settings/tokens)
GITHUB_TOKEN=your_github_personal_access_token

# Session Configuration
# Required: Secret password for encrypting session cookies (min 32 characters)
# Generate with: openssl rand -base64 32
SESSION_PASSWORD=your_super_secret_session_password_min_32_characters

# Admin Configuration
# Optional: Override default admin credentials (default: admin/admin123)
# Generate password hash with: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$YourHashedPasswordHere

# Password for protected pages/routes (unused)
